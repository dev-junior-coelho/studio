/**
 * @fileoverview Firestore Security Rules for the Studio App application.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for saved offers and role-based access to user profiles.
 *
 * Data Structure:
 * - /produtos/{produtoId}: Public read access, no write access.
 * - /procedimentos/{procedimentoId}: Public read access, no write access.
 * - /regioes/{regiaoId}: Public read access, no write access.
 * - /usuarios/{usuarioId}: User profile information; only the authenticated user can read/write their own profile.
 * - /users/{userId}/ofertas_salvas/{ofertaSalvaId}: Saved offers for a specific user; only the owner can create, read, update, or delete.
 *
 * Key Security Decisions:
 * - Listing of users is disallowed.
 * - Public read access granted to products, procedures, and regions as these are assumed to be public resources.
 *
 * Denormalization for Authorization:
 * - The `OfertaSalva` documents are located under `/users/{userId}` and contain the `usuarioId` field. This setup avoids the need for `get()` calls in security rules to check user roles or permissions, enabling atomic operations and simplifying security logic.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows public read access to product information.  No write access.
     * @path /produtos/{produtoId}
     * @allow get, list: Any user can read product details.
     * @deny create, update, delete: No user can create, update, or delete product details.
     * @principle Allows public read access to product information; writes are disallowed.
     */
    match /produtos/{produtoId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    /**
     * @description Allows public read access to procedure guides. No write access.
     * @path /procedimentos/{procedimentoId}
     * @allow get, list: Any user can read procedure guides.
     * @deny create, update, delete: No user can create, update, or delete procedure guides.
     * @principle Allows public read access to procedure guides; writes are disallowed.
     */
    match /procedimentos/{procedimentoId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    /**
     * @description Allows public read access to region information. No write access.
     * @path /regioes/{regiaoId}
     * @allow get, list: Any user can read region data.
     * @deny create, update, delete: No user can modify region data.
     * @principle Grants read access to essential app data for all users.
     */
    match /regioes/{regiaoId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    /**
     * @description Allows authenticated users to read and write their own user profile.
     *              Supervisors can also read and update any user profile (for promote/demote/sync).
     * @path /usuarios/{usuarioId}
     * @allow get: Owner or supervisor can read a profile.
     * @allow list: Only supervisors can list all profiles.
     * @allow create: Only the owner can create their own profile.
     * @allow update: Owner can update their own profile; supervisors can update any profile.
     * @deny delete: No one can delete profiles.
     * @principle Enforces user-ownership with supervisor override for management operations.
     */
    match /usuarios/{usuarioId} {
      allow get: if isSignedIn() && (isOwner(usuarioId) || isSupervisor());
      allow list: if isSignedIn() && isSupervisor();
      allow create: if isSignedIn() && isOwner(usuarioId) && isValidUserCreate(usuarioId);
      allow update: if isSignedIn() && (
        (isOwner(usuarioId) && isSafeOwnerProfileUpdate()) ||
        (isSupervisor() && isSafeSupervisorProfileUpdate())
      );
      allow delete: if false;
    }

    /**
     * @description Allows the owner or a supervisor to manage saved offers.
     * @path /usuarios/{userId}/ofertas_salvas/{ofertaSalvaId}
     */
    match /usuarios/{userId}/ofertas_salvas/{ofertaSalvaId} {
      allow read: if isSignedIn() && (isOwner(userId) || isSupervisor());
      allow create: if isSignedIn() && isOwner(userId) && isValidOfferCreate(userId);
      allow update: if isSignedIn() && (isOwner(userId) || isSupervisor()) && isValidOfferUpdate(userId);
      allow delete: if isSignedIn() && (isOwner(userId) || isSupervisor());
    }

    /**
     * @description Collection Group helper for supervisors to see everything.
     */
    match /{path=**}/ofertas_salvas/{ofertaSalvaId} {
      allow read: if isSignedIn() && isSupervisor();
    }
  }

  // Helper functions
  function isSignedIn() {
    return request.auth != null;
  }

  function isOwner(userId) {
    return request.auth.uid == userId;
  }

  function isSupervisor() {
    return isSignedIn() && 
           exists(/databases/$(database)/documents/usuarios/$(request.auth.uid)) &&
           get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.role == 'supervisor';
  }

  function userCreateKeys() {
    return [
      'uid',
      'email',
      'role',
      'nome',
      'zLogin',
      'supervisor',
      'lastSeen',
      'isTest'
    ];
  }

  function protectedUserFields() {
    return [
      'uid',
      'email',
      'role',
      'zLogin',
      'isTest',
      'promotedBy',
      'promotedAt',
      'demotedBy',
      'demotedAt'
    ];
  }

  function supervisorManagedFields() {
    return [
      'role',
      'supervisor',
      'promotedBy',
      'promotedAt',
      'demotedBy',
      'demotedAt'
    ];
  }

  function isValidUserCreate(userId) {
    return request.resource.data.keys().hasOnly(userCreateKeys()) &&
           request.resource.data.keys().hasAll(['uid', 'email', 'role', 'zLogin']) &&
           request.resource.data.uid == userId &&
           request.resource.data.role == 'agente' &&
           request.resource.data.zLogin is string &&
           request.resource.data.zLogin.matches('^[0-9]{6}$') &&
           request.resource.data.email == request.auth.token.email &&
           request.resource.data.email.matches('^z[0-9]{6}@interno[.]studioclaro[.]app$') &&
           (!('nome' in request.resource.data) || request.resource.data.nome is string) &&
           (!('supervisor' in request.resource.data) || request.resource.data.supervisor is string) &&
           (!('lastSeen' in request.resource.data) || request.resource.data.lastSeen is string || request.resource.data.lastSeen == null) &&
           (!('isTest' in request.resource.data) || request.resource.data.isTest is bool);
  }

  function isSafeOwnerProfileUpdate() {
    return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastSeen', 'supervisor', 'nome']) &&
           !request.resource.data.diff(resource.data).affectedKeys().hasAny(protectedUserFields()) &&
           (!('lastSeen' in request.resource.data) || request.resource.data.lastSeen is string || request.resource.data.lastSeen == null) &&
           (!('supervisor' in request.resource.data) || request.resource.data.supervisor is string) &&
           (!('nome' in request.resource.data) || request.resource.data.nome is string);
  }

  function isSafeSupervisorProfileUpdate() {
    return request.resource.data.diff(resource.data).affectedKeys().hasOnly(supervisorManagedFields()) &&
           (!('role' in request.resource.data) || request.resource.data.role in ['agente', 'supervisor']) &&
           (!('supervisor' in request.resource.data) || request.resource.data.supervisor is string) &&
           (!('promotedBy' in request.resource.data) || request.resource.data.promotedBy is string) &&
           (!('promotedAt' in request.resource.data) || request.resource.data.promotedAt is string) &&
           (!('demotedBy' in request.resource.data) || request.resource.data.demotedBy is string) &&
           (!('demotedAt' in request.resource.data) || request.resource.data.demotedAt is string);
  }

  function offerCreateKeys() {
    return [
      'usuarioId',
      'email',
      'nome',
      'supervisor',
      'zLogin',
      'produtoIds',
      'produtos',
      'status',
      'contrato',
      'timestamp',
      'totalOferta',
      'economia',
      'debitoEmConta',
      'descontoDCC'
    ];
  }

  function isValidOfferCreate(userId) {
    return request.resource.data.keys().hasOnly(offerCreateKeys()) &&
           request.resource.data.keys().hasAll(['usuarioId', 'status', 'timestamp']) &&
           request.resource.data.usuarioId == userId &&
           request.resource.data.status in ['Aceitou', 'Recusou'] &&
           (!('totalOferta' in request.resource.data) || request.resource.data.totalOferta is number) &&
           (!('economia' in request.resource.data) || request.resource.data.economia is number) &&
           (!('descontoDCC' in request.resource.data) || request.resource.data.descontoDCC is number) &&
           (!('debitoEmConta' in request.resource.data) || request.resource.data.debitoEmConta is bool);
  }

  function isValidOfferUpdate(userId) {
    return request.resource.data.usuarioId == resource.data.usuarioId &&
           resource.data.usuarioId == userId;
  }
}
